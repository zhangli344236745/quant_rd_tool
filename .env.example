# OpenAI-compatible (LiteLLM default for RD-Agent)
OPENAI_API_KEY=
CHAT_MODEL=gpt-4o
EMBEDDING_MODEL=text-embedding-3-small
# OPENAI_API_BASE=

# API server
QUANT_RD_HOST=127.0.0.1
QUANT_RD_PORT=8765

# Enterprise module (optional, dual-track; default off)
# QUANT_RD_ENTERPRISE_ENABLED=false
# QUANT_RD_API_KEYS=your-internal-key
# QUANT_RD_ADMIN_PASSWORD=change-me

# Market data: auto | akshare | openbb
QUANT_RD_DATA_PROVIDER=auto

# OpenBB optional providers (macro panel FRED / FMP peers)
# FRED_API_KEY=
# FMP_API_KEY=

# Binance (ccxt bot) — 默认 dry-run；测试网 BINANCE_TESTNET=true
# BINANCE_API_KEY=
# BINANCE_API_SECRET=
# BINANCE_TESTNET=false
# BINANCE_API_BASE=https://api.binance.com   # 可改成 https://api1.binance.com / https://api2.binance.com / https://api3.binance.com

# Network proxy (optional, for ccxt/binance connectivity)
# HTTP_PROXY=http://127.0.0.1:7890
# HTTPS_PROXY=http://127.0.0.1:7890

# Crypto scheduler (5m incremental sync every 30 minutes)
# CRYPTO_SCHEDULE_SYMBOLS=BTC,ETH
# CRYPTO_SCHEDULE_TIMEFRAME=5m
# CRYPTO_SCHEDULE_INTERVAL_MIN=30
# CRYPTO_SCHEDULE_BACKFILL_DAYS=90

# Bark 手机推送（定时任务告警）；配置 Key 后可在页面直接开启 Bark 推送
# BARK_DEVICE_KEY=
# BARK_SERVER=https://api.day.app

# Crypto news sentiment (optional overrides for settings.json crypto_news)
# CRYPTO_NEWS_LLM_TOP_N=5
# CRYPTO_NEWS_MIN_SCORE=40
# CRYPTO_NEWS_WEB_SEARCH_ENABLED=true
# CRYPTO_NEWS_SEARCH_MONTHLY_LIMIT=150

# Web search for crypto news (optional; costs apply — enable in UI or env)
# TAVILY_API_KEY=
# SERPAPI_API_KEY=
